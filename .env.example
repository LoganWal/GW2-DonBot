# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# Used by docker-compose. For local development without Docker, use appsettings.user.json
# in each project directory instead (same key names, nested keys become JSON objects).

# ── Required ────────────────────────────────────────────────────────────────

# Discord bot token (discord.com/developers/applications → Bot → Token)
DonBotToken=your-discord-bot-token

# PostgreSQL connection string
DonBotSqlConnectionString=Host=localhost;Port=5432;Database=DonBot;Username=postgres;Password=yourpassword;

# Discord OAuth2 app credentials (discord.com/developers/applications → OAuth2)
DiscordClientId=your-discord-app-client-id
DiscordClientSecret=your-discord-app-client-secret

# JWT signing key for the API - min 32 random chars
# Generate with: openssl rand -base64 32
DonBotJwtKey=

# ── URLs ────────────────────────────────────────────────────────────────────

# Discord OAuth2 callback URL - must match what is registered in the Discord developer portal
Discord__RedirectUri=https://yourapi.com/auth/discord/callback

# URL of the Nuxt frontend - used by the API to redirect after OAuth login
Nuxt__BaseUrl=https://yourapp.com

# URL of the API - used by the frontend at runtime to make API calls
NUXT_PUBLIC_API_BASE=https://yourapi.com

# Base URL of the web app - if set, WvW fight summary embeds include a "View on DonBot" link
WebApp__BaseUrl=https://yourapp.com

# ── Auth / cookies ──────────────────────────────────────────────────────────

# Cookie domain - set to .yourdomain.com in production so the auth cookie works across subdomains
CookieDomain=

# Allowed CORS origins for the API - uncomment and repeat for each origin
# Cors__AllowedOrigins__0=https://yourapp.com

# ── Log uploads (optional) ──────────────────────────────────────────────────

# Absolute path to the Elite Insights CLI .dll (or .exe)
# Required only if you want to accept .zevtc file uploads
# Download: https://github.com/baaron4/GW2-Elite-Insights-Parser/releases
EliteInsights__DllPath=/opt/ei/GuildWars2EliteInsights-CLI.dll

# Directory where EI writes per-job HTML/log output (created automatically)
EliteInsights__OutputBasePath=/tmp/donbot/ei-output

# Directory where uploaded .zevtc files are stored during processing (created automatically)
Upload__StoragePath=/tmp/donbot/uploads

# Optional dps.report user token - links uploads to your dps.report account
DpsReport__UserToken=

# ── Docker / Watchtower ──────────────────────────────────────────────────────

# GitHub username and PAT (read:packages scope) for Watchtower to pull images from GHCR
GHCR_USER=your-github-username
GHCR_TOKEN=your-ghcr-personal-access-token
