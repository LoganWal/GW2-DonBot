# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# All of these can alternatively be set in DonBot.Api/appsettings.user.json
# using the same key names (nested keys use JSON objects, e.g. Discord: { RedirectUri: ... }).

# Discord bot token
DonBotToken=your-discord-bot-token

# Postgres connection string
DonBotSqlConnectionString=Host=localhost;Port=5432;Database=DonBot;Username=postgres;Password=yourpassword;

# Discord OAuth app credentials (discord.com/developers/applications)
DiscordClientId=your-discord-app-client-id
DiscordClientSecret=your-discord-app-client-secret

# JWT signing key - min 32 random chars (e.g. openssl rand -base64 32)
DonBotJwtKey=

# OAuth callback URI - must match what is registered in the Discord developer portal
Discord__RedirectUri=http://localhost:5001/auth/discord/callback

# URL of the Nuxt frontend - used by the API to redirect after OAuth
Nuxt__BaseUrl=http://localhost:3000

# Allowed CORS origins for the API - comma separated, leave unset to allow all localhost origins
# Cors__AllowedOrigins__0=https://yoursite.com

# Nuxt public config - API base URL used by the frontend at build/runtime
NUXT_PUBLIC_API_BASE=http://localhost:5001

# Web app base URL - if set, fight log embeds will include a link to view logs on the site
WebApp__BaseUrl=https://yourapp.com

# Cookie domain - set to .yourdomain.com in production so auth cookie is shared across subdomains
CookieDomain=

# GitHub Container Registry credentials for Watchtower auto-updates
GHCR_USER=your-github-username
GHCR_TOKEN=your-ghcr-personal-access-token
