{
  // ── Required ────────────────────────────────────────────────────────────────
  // Copy this file to appsettings.user.json and fill in your values.
  // appsettings.user.json is gitignored and loaded automatically at startup.

  "DonBotToken": "your-discord-bot-token",
  "DonBotSqlConnectionString": "Host=localhost;Port=5432;Database=DonBot;Username=postgres;Password=yourpassword;",

  // Discord OAuth2 app credentials (discord.com/developers/applications → OAuth2)
  "DiscordClientId": "your-discord-app-client-id",
  "DiscordClientSecret": "your-discord-app-client-secret",

  // JWT signing key - min 32 random chars. Generate with: openssl rand -base64 32
  "DonBotJwtKey": "",

  // ── URLs ────────────────────────────────────────────────────────────────────

  "Discord": {
    // Must match the redirect URI registered in the Discord developer portal
    "RedirectUri": "http://localhost:5001/auth/discord/callback"
  },

  "Nuxt": {
    // URL of the Nuxt frontend - used by the API to redirect after OAuth login
    "BaseUrl": "http://localhost:3000"
  },

  "WebApp": {
    // Base URL of the web app - if set, WvW fight summary embeds include a "View on DonBot" link
    "BaseUrl": "https://yourapp.com"
  },

  // ── Auth / cookies ──────────────────────────────────────────────────────────

  // Cookie domain - set to .yourdomain.com in production so the auth cookie works across subdomains
  "CookieDomain": "",

  "Cors": {
    // Allowed origins for the API. If empty, any localhost origin is allowed (local dev only).
    "AllowedOrigins": []
  },

  // ── Log uploads (optional) ──────────────────────────────────────────────────

  "EliteInsights": {
    // Absolute path to the EI CLI .dll (or .exe). Required for .zevtc file uploads.
    // Download: https://github.com/baaron4/GW2-Elite-Insights-Parser/releases
    "DllPath": "/opt/ei/GuildWars2EliteInsights-CLI.dll",

    // Directory where EI writes per-job HTML/log output (created automatically)
    "OutputBasePath": "/tmp/donbot/ei-output"
  },

  "Upload": {
    // Root directory for uploaded .zevtc files (created automatically)
    "StoragePath": "/tmp/donbot/uploads",

    // Kestrel max request body size in bytes (default 1 GB - TUS chunks are 50 MB each)
    "MaxRequestBytes": 1073741824,

    // Max number of upload pipeline jobs processed in parallel
    "MaxConcurrentProcessing": 3
  },

  "DpsReport": {
    // Optional dps.report user token - links uploads to your dps.report account
    "UserToken": ""
  }
}
